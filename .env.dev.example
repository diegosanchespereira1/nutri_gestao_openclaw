# =============================================================================
# Ambiente DEV (Docker build local + referência para secrets do GitHub Actions)
# =============================================================================
# Copiar para .env.dev e preencher (ficheiro .env.dev está em .gitignore).
#
# GitHub → Settings → Secrets and variables → Actions — criar estes secrets
# para o job "Docker DEV" publicar stratostech/nutricao-stratostech:dev:
#   NEXT_PUBLIC_SUPABASE_URL_DEV
#   NEXT_PUBLIC_SUPABASE_ANON_KEY_DEV
#   NEXT_PUBLIC_SITE_URL_DEV          (ex.: https://dev-nutricao.stratostech.com.br)
# Opcional mas recomendado (mesma chave entre builds do mesmo ambiente DEV):
#   NEXT_SERVER_ACTIONS_ENCRYPTION_KEY_DEV
#
# Produção (imagem :latest) continua a usar os secrets sem sufixo _DEV:
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   NEXT_PUBLIC_SITE_URL
#   NEXT_SERVER_ACTIONS_ENCRYPTION_KEY
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://dbhmlnutricao.stratostech.com.br
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ewogICJyb2xlIjogImFub24iLAogICJpc3MiOiAic3VwYWJhc2UiLAogICJpYXQiOiAxNzE1MDUwODAwLAogICJleHAiOiAxODcyODE3MjAwCn0.01MIDlUim2PV62jgYajIW5FYHdzFisYNhGtkoir4vjQ

NEXT_PUBLIC_SITE_URL=https://dev-nutricao.stratostech.com.br

# Postgres DEV — migrações locais (scripts/database/push-migrations-dev.sh).
# Copie scripts/database/env.dev.example → scripts/database/.env.dev e preencha.
# SUPABASE_DB_URL_DEV=postgresql://postgres:SENHA@HOST:5432/postgres

# Gerar uma vez e manter estável: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
#
# Origens extra para Content-Security-Policy (connect-src), se necessário no build:
# CSP_CONNECT_SRC_EXTRA=https://dbhmlnutricao.stratostech.com.br wss://dbhmlnutricao.stratostech.com.br
