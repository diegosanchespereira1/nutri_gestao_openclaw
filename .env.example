# Copiar para .env.local (nunca commitar .env.local).
# Com Supabase local: `supabase start` e `supabase status` para URL e anon key.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: URL canónica da app para links de email (confirmação, reset).
# Use se alternar entre http://localhost:3000 e http://127.0.0.1:3000 — as Redirect URLs no Dashboard
# têm de incluir AMBAS ou fixar uma e igualar esta variável.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Não usar SUPABASE_SERVICE_ROLE_KEY no cliente nem em NEXT_PUBLIC_*.
#
# Passwords: alinhar o mínimo do Dashboard (Authentication → Providers → Email)
# com a app — atualmente o registo exige pelo menos 12 caracteres no cliente.
#
# Auth: no Supabase Dashboard configurar Site URL e Redirect URLs para, no mínimo:
#   http://localhost:3000/auth/callback
#   http://127.0.0.1:3000/auth/callback
#   {SITE_URL}/auth/reset-password
# Ver _bmad-output/implementation-artifacts/epic-1-supabase-equipe-checklist.md
#
# Envio do dossiê por email (Story 4.9 — Resend):
# RESEND_API_KEY=re_...
# DOSSIER_EMAIL_FROM="NutriGestão <noreply@seudominio.com>"
# (alternativa ao remetente: RESEND_FROM_EMAIL)
# Em desenvolvimento, o domínio de teste da Resend só envia para o email da conta.
