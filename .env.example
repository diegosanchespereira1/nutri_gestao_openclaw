# Copiar para .env.local (nunca commitar .env.local).
# Com Supabase local: `supabase start` e `supabase status` para URL e anon key.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL canónica da app (produção: https://...). Usada para cookies Secure alinhados com HTTPS.
# Emails de confirmação/reset e cookies de sessão: manter igual ao domínio real.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Não usar SUPABASE_SERVICE_ROLE_KEY no cliente nem em NEXT_PUBLIC_*.
# Em produção (servidor/API routes): necessária para POST /api/auth/troubleshooting gravar logs.
# SUPABASE_SERVICE_ROLE_KEY=
#
# Passwords: alinhar o mínimo do Dashboard (Authentication → Providers → Email)
# com a app — atualmente o registo exige pelo menos 12 caracteres no cliente.
#
# Auth: no Supabase Dashboard configurar Site URL e Redirect URLs para, no mínimo:
#   http://localhost:3000/auth/callback
#   http://127.0.0.1:3000/auth/callback
#   {SITE_URL}/auth/reset-password
# Ver _bmad-output/implementation-artifacts/epic-1-supabase-equipe-checklist.md
#
# Envio do dossiê por email (Story 4.9 — Resend):
# RESEND_API_KEY=re_...
# DOSSIER_EMAIL_FROM="NutriGestão <noreply@seudominio.com>"
# (alternativa ao remetente: RESEND_FROM_EMAIL)
# Em desenvolvimento, o domínio de teste da Resend só envia para o email da conta.

# Rate Limiting (Story 11.2 — Auditoria):
# Criar database no Upstash (https://upstash.com) e obter as chaves
# UPSTASH_REDIS_REST_URL=https://...redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Em desenvolvimento local, pode ficar vazio (rate limiting será desativado gracefully)

# Sessão na aplicação (cookies HttpOnly paralelos ao JWT Supabase):
# - AUTH_SESSION_ABSOLUTE_MAX_SEC: tempo máximo em segundos após o início da sessão local (default 28800 = 8 h).
# - AUTH_SESSION_IDLE_TIMEOUT_SEC: inactividade máxima em segundos sem pedidos à app (default 2700 = 45 min).
# Alinhar também no Supabase → Authentication → Sessions (JWT expiry, refresh) com a política da equipa.
# AUTH_SESSION_ABSOLUTE_MAX_SEC=28800
# AUTH_SESSION_IDLE_TIMEOUT_SEC=2700
