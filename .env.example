# Copiar para .env.local (nunca commitar .env.local).
# Com Supabase local: `supabase start` e `supabase status` para URL e anon key.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL canónica da app (produção: https://...). Links em emails de auth e transacionais.
# NEXT_PUBLIC_APP_VERSION=1.2.19
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Não usar SUPABASE_SERVICE_ROLE_KEY no cliente nem em NEXT_PUBLIC_*.
# SUPABASE_SERVICE_ROLE_KEY=

# ── Email: autenticação (convite, reset, confirmação) ─────────────────────────
# Configurar SMTP no Supabase Auth (GoTrue) do self-hosted — mesmo domínio.
# No docker do Supabase (ex.: .env do stack):
#   GOTRUE_SMTP_HOST=smtp.seudominio.com
#   GOTRUE_SMTP_PORT=587
#   GOTRUE_SMTP_USER=...
#   GOTRUE_SMTP_PASS=...
#   GOTRUE_SMTP_ADMIN_EMAIL=noreply@seudominio.com
#   GOTRUE_SMTP_SENDER_NAME=NutriGestão
# Templates HTML: supabase/templates/ (invite, recovery, confirmation)
#
# Redirect URLs no Auth: {SITE_URL}/auth/callback, {SITE_URL}/auth/reset-password

# ── Email: transacional da app (dossiê PDF, portal externo, LGPD) ─────────────
# Use o MESMO servidor SMTP do seu domínio (não é o GoTrue; é a app Next.js).
# SMTP_HOST=smtp.seudominio.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM="NutriGestão <noreply@seudominio.com>"

# Rate Limiting (Story 11.2 — Auditoria):
# UPSTASH_REDIS_REST_URL=https://...redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Sessão na aplicação:
# AUTH_SESSION_ABSOLUTE_MAX_SEC=28800
# AUTH_SESSION_IDLE_TIMEOUT_SEC=2700

# Mobile / Capacitor:
# NEXT_PUBLIC_IS_CAPACITOR_BUILD=true
