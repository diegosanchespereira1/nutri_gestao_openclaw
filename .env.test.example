# ================================================================
# .env.test — Variáveis para testes RLS multi-tenant
# Copie este ficheiro para .env.test e preencha com os valores
# da sua instância local do Supabase (npx supabase start).
#
# NUNCA commitar .env.test com valores reais!
# ================================================================

# URL da instância Supabase local (default do supabase start)
SUPABASE_TEST_URL=http://127.0.0.1:54321

# Chave anon (gerada pelo supabase start — segura para expor)
SUPABASE_TEST_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave service_role (NUNCA expor em produção — apenas testes locais/CI)
SUPABASE_TEST_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Credenciais dos utilizadores de teste (criados automaticamente pelo seed)
# Deixar como estão — o seed usa estes valores para criar os users
TEST_TENANT_A_EMAIL=tenant_a_rls@nutrigestao.test
TEST_TENANT_A_PASSWORD=RlsTest@TenantA2026!

TEST_TENANT_B_EMAIL=tenant_b_rls@nutrigestao.test
TEST_TENANT_B_PASSWORD=RlsTest@TenantB2026!
