# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Python / dumps locais (não versionar)
__pycache__/
backups/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (segredos — nunca commitar)
.env*
!.env.example
!.env.dev.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Test environment (credenciais locais — nunca commitar)
.env.test
!.env.test.example

# Capacitor — plataformas nativas geradas
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
android/.gradle/
android/app/build/
android/build/
android/local.properties

# Android — keystore de assinatura (NUNCA commitar — perder = não atualizar mais o app)
*.keystore
*.jks
android/keystore.properties
