#!/usr/bin/env sh
# Opcional: BUMP_APP_VERSION_ON_COMMIT=1 git commit …
# Incrementa patch + ficheiros nativos (ver scripts/version/README.md).
if [ "${BUMP_APP_VERSION_ON_COMMIT:-}" != "1" ]; then
  exit 0
fi

set -e
node scripts/version/bump-app-version.mjs
git add package.json android/app/build.gradle ios/App/App.xcodeproj/project.pbxproj
