# Variáveis esperadas por docker-compose-prd.yml (Swarm / Portainer + Traefik).
#
# Uso:
# - Portainer: colar no editor "Environment" da stack (KEY=VAL por linha).
# - CLI: copiar para `.env` na mesma pasta do compose:
#     cp docker-compose-prd.env.example .env
#   depois preencher valores reais (nunca commitar `.env` com segredos).
#
# Referência do compose: docker-compose-prd.yml

# Imagem da app (default no YAML: stratostech/nutricao-stratostech:latest)
# NUTRICAO_IMAGE=stratostech/nutricao-stratostech:latest

# Supabase — servidor e anon (SSR + browser; podem repetir URL/anon)
# SUPABASE_URL=                    # opcional se NEXT_PUBLIC_SUPABASE_URL estiver definida
NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_ANON_KEY=               # opcional se NEXT_PUBLIC_SUPABASE_ANON_KEY estiver definida
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública da app (emails, redirects, cookies alinhados ao domínio)
NEXT_PUBLIC_SITE_URL=https://nutricao.stratostech.com.br

# Servidor apenas — nunca expor ao cliente
SUPABASE_SERVICE_ROLE_KEY=

# Dossiê por email (opcional se não usares)
# RESEND_API_KEY=
# DOSSIER_EMAIL_FROM="NutriGestão <noreply@seudominio.com>"

# Traefik — host público (deve coincidir com DNS apontado ao cluster)
# APP_HOST=nutricao.stratostech.com.br

# Traefik — só necessário se várias stacks partilharem labels (evitar colisão de nomes)
# TRAEFIK_ROUTER_NAME=nutricao-app
# TRAEFIK_SERVICE_NAME=nutricao-app
# TRAEFIK_MIDDLEWARE_NAME=nutricao-sslheader
