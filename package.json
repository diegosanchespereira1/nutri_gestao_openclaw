{
  "name": "nutricao-gestao",
  "version": "1.2.11",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "npx next dev",
    "build": "npx next build",
    "start": "npx next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rls": "vitest run --config vitest.config.rls.ts",
    "test:rls:watch": "vitest --config vitest.config.rls.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "mobile:sync": "npx cap sync && node scripts/mobile/ensure-android-package-id.mjs",
    "mobile:android:bundle": "npm run mobile:sync && node scripts/mobile/check-android-release-keystore.mjs && node scripts/mobile/run-android-gradle.mjs bundleRelease",
    "mobile:ios": "npx cap open ios",
    "mobile:android": "npx cap open android",
    "mobile:run:ios": "npx cap run ios",
    "mobile:run:android": "npx cap run android",
    "mobile:assets": "npm run mobile:icons",
    "mobile:icons": "node scripts/mobile/prepare-app-icons.mjs",
    "mobile:store-assets": "node scripts/mobile/generate-store-assets.mjs",
    "mobile:store-screenshots": "playwright test e2e/store-screenshots.spec.ts --workers=1",
    "mobile:check-production": "node scripts/mobile/check-mobile-production-deploy.mjs",
    "mobile:android:debug": "CAP_WEBVIEW_DEBUG=true npx cap sync android && npx cap run android",
    "mobile:android:local": "node scripts/mobile/capacitor-use-local-server.mjs",
    "version:bump-patch": "node scripts/version/bump-app-version.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.86.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "heic-to": "^1.4.3",
    "isomorphic-dompurify": "^2.9.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "react": "19.2.7",
    "react-dom": "19.2.4",
    "recharts": "^2.15.4",
    "resend": "^4.8.0",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "8.5.10",
    "tmp": "0.2.7",
    "uuid": "14.0.0",
    "esbuild": "0.28.1",
    "minimatch": "10.2.5",
    "tar": "7.5.16"
  }
}
